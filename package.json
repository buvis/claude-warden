{
  "name": "@buvis/claude-warden",
  "version": "0.2.3",
  "description": "Smart command safety filter for Claude Code - auto-approves safe commands, blocks dangerous ones",
  "type": "module",
  "main": "dist/index.cjs",
  "license": "MIT",
  "author": "buvis",
  "repository": {
    "type": "git",
    "url": "https://github.com/buvis/claude-warden.git"
  },
  "homepage": "https://github.com/buvis/claude-warden",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "claude-code",
    "claude-code-plugin",
    "safety",
    "security",
    "shell",
    "command-filter"
  ],
  "files": [
    "dist",
    ".claude-plugin",
    "hooks",
    "config",
    "marketplace.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "eval": "node dist/index.cjs",
    "codex:export-rules": "node dist/codex-export.cjs",
    "sync-plugin-version": "node -e \"const p=require('./package.json'),fs=require('fs'),f='.claude-plugin/plugin.json',j=JSON.parse(fs.readFileSync(f));j.version=p.version;fs.writeFileSync(f,JSON.stringify(j,null,2)+'\\n')\"",
    "release": "scripts/release.sh patch",
    "release:minor": "scripts/release.sh minor",
    "release:major": "scripts/release.sh major",
    "prepublishOnly": "pnpm run sync-plugin-version && pnpm run build && pnpm run test",
    "postpublish": "claude plugin update warden@buvis-plugins 2>/dev/null; echo 'Plugin cache updated'"
  },
  "dependencies": {
    "bash-parser": "^0.5.0",
    "yaml": "^2.4.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
