{
  "name": "claude-warden",
  "version": "2.3.2",
  "description": "Smart command safety filter for Claude Code — auto-approves safe commands, blocks dangerous ones",
  "type": "module",
  "main": "dist/index.cjs",
  "license": "MIT",
  "author": "banyudu",
  "repository": {
    "type": "git",
    "url": "https://github.com/banyudu/claude-warden.git"
  },
  "homepage": "https://github.com/banyudu/claude-warden",
  "keywords": [
    "claude-code",
    "claude-code-plugin",
    "safety",
    "security",
    "shell",
    "command-filter"
  ],
  "files": [
    "dist",
    ".claude-plugin",
    "hooks",
    "config",
    "marketplace.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "eval": "node dist/index.cjs",
    "codex:export-rules": "node dist/codex-export.cjs",
    "sync-plugin-version": "node scripts/sync-plugin-version.cjs",
    "release": "scripts/release.sh patch",
    "release:minor": "scripts/release.sh minor",
    "release:major": "scripts/release.sh major",
    "prepublishOnly": "pnpm run sync-plugin-version && pnpm run build && pnpm run test",
    "postpublish": "claude plugin update claude-warden@local 2>/dev/null; claude plugin update warden@claude-warden 2>/dev/null; echo 'Plugin caches updated'",
    "docs:dev": "cd docs-src && pnpm dev",
    "docs:build": "cd docs-src && pnpm install && pnpm build"
  },
  "dependencies": {
    "bash-parser": "npm:@banyudu/bash-parser@0.5.2",
    "yaml": "^2.4.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
