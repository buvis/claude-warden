{
  "name": "@buvis/claude-warden",
  "version": "0.9.0",
  "description": "Smart command safety filter for Claude Code - auto-approves safe commands, blocks dangerous ones",
  "type": "module",
  "main": "dist/index.cjs",
  "bin": {
    "warden": "dist/cli.cjs",
    "warden-hook": "dist/index.cjs"
  },
  "license": "MIT",
  "author": "buvis",
  "repository": {
    "type": "git",
    "url": "https://github.com/buvis/claude-warden.git"
  },
  "homepage": "https://github.com/buvis/claude-warden",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "claude-code",
    "claude-code-plugin",
    "copilot",
    "copilot-cli",
    "safety",
    "security",
    "shell",
    "command-filter"
  ],
  "files": [
    "dist",
    ".claude-plugin",
    ".claude",
    ".github/hooks",
    ".codex",
    "hooks",
    "config",
    "marketplace.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup && chmod +x dist/*.cjs",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "eval": "node dist/index.cjs",
    "warden": "node dist/cli.cjs",
    "codex:export-rules": "node dist/codex-export.cjs",
    "sync-plugin-version": "node scripts/sync-plugin-version.cjs",
    "release": "dev/bin/release patch",
    "release:minor": "dev/bin/release minor",
    "release:major": "dev/bin/release major",
    "prepublishOnly": "pnpm run sync-plugin-version && pnpm run build && pnpm run test && chmod +x dist/*.cjs",
    "postpublish": "claude plugin update warden@buvis-plugins 2>/dev/null; echo 'Plugin cache updated'"
  },
  "dependencies": {
    "unbash": "^2.2.0",
    "yaml": "^2.4.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
